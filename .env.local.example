NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Clerk Dashboard → Webhooks → endpoint Signing secret (whsec_..., NOT the Secret key)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_clerk_webhook_signing_secret
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Groq (https://console.groq.com/keys) — keys start with gsk_
GROQ_API_KEY=
# Optional override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=
# Groq on-demand TPM for llama-3.3-70b-versatile is 12000 (input + max_tokens). Override if your tier differs.
# GROQ_TPM_LIMIT=12000

# Anthropic Claude only (sk-ant-...). Used when GROQ_API_KEY is unset.
ANTHROPIC_API_KEY=
# All routes — use a model id from https://docs.anthropic.com/en/docs/about-claude/models
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional phase-1 override (defaults to ANTHROPIC_MODEL)
# ANTHROPIC_CORE_MODEL=claude-sonnet-4-6
# Token caps per API phase (lower = faster generation)
ANTHROPIC_CORE_MAX_OUTPUT_TOKENS=10000
ANTHROPIC_TECH_STACK_MAX_OUTPUT_TOKENS=8000
ANTHROPIC_SYSTEM_DESIGN_MAX_OUTPUT_TOKENS=5000

# Dev: your dev project URL/keys. Production (Vercel only): kgqipjwimufoqpgciczv
# NEXT_PUBLIC_SUPABASE_URL=https://kgqipjwimufoqpgciczv.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: Supabase Dashboard → Project Settings → API (never commit)
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Paddle Billing (https://vendors.paddle.com)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_VENDOR_ID=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# sandbox | production
PADDLE_ENVIRONMENT=sandbox

# Price IDs from Paddle Dashboard (pri_…)
PADDLE_BLUEPRINT_PRICE_ID=
PADDLE_PRO_PRICE_ID=
PADDLE_TEAM_PRICE_ID=

# Dev only — simulate billing tier locally (ignored in production)
# SIMULATE_USER_PLAN=free
# SIMULATE_GENERATION_COUNT=0
